# Postgres connection (Coolify will give you this when you add the Postgres service)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kantin_rms?schema=public"

# NextAuth - generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-me-with-32-bytes"
NEXTAUTH_URL="https://kantin.iespl.org"

# Seed-time admin (used only by `npm run db:seed` on first deploy)
SEED_ADMIN_EMAIL="admin@iespl.org"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Administrator"
