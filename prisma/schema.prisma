// Kantin RMS — Postgres schema
// Generated by Prisma. Runs on the Coolify-managed Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// AUTH
// =========================================================================

enum Role {
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(VIEWER)
  kantinSlug   String?  // null = global (all kantins). admins are typically global.
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  grnsCreated      Grn[]            @relation("GrnCreatedBy")
  stockMovementsBy StockMovement[]  @relation("StockMovementBy")
  stockTakesBy     StockTake[]      @relation("StockTakeBy")

  @@index([kantinSlug])
}

// =========================================================================
// KANTINS — explicit table so we can scope features per location
// =========================================================================

model Kantin {
  slug       String   @id
  name       String
  city       String
  fullAddress String?
  isLive     Boolean  @default(false)
  createdAt  DateTime @default(now())

  vendors        Vendor[]
  products       Product[]
  grns           Grn[]
  stockMovements StockMovement[]
  stockTakes     StockTake[]
}

// =========================================================================
// VENDORS / SUPPLIERS
// =========================================================================

model Vendor {
  id         String   @id @default(cuid())
  kantinSlug String
  name       String
  contact    String?
  phone      String?
  address    String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  kantin Kantin @relation(fields: [kantinSlug], references: [slug])
  grns   Grn[]

  @@index([kantinSlug])
}

// =========================================================================
// PRODUCTS / RAW MATERIALS
// =========================================================================

enum ProductKind {
  RAW_MATERIAL   // ingredients (potato, oil, cheese)
  PACKAGING      // boxes, paper bags
  RESALE         // bottles of water, packaged drinks
  SUPPLIES       // non-food consumables
}

enum StockUnit {
  KG
  GRAM
  LITRE
  ML
  PIECE
  PACK
  BOX
  BOTTLE
}

model Product {
  id           String      @id @default(cuid())
  kantinSlug   String
  sku          String?     // optional barcode / internal code
  name         String
  kind         ProductKind @default(RAW_MATERIAL)
  unit         StockUnit   @default(PIECE)
  minStock     Float       @default(0)
  costPerUnit  Float?      // last known unit cost (updated by GRN)
  isActive     Boolean     @default(true)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  kantin         Kantin          @relation(fields: [kantinSlug], references: [slug])
  grnLines       GrnLine[]
  stockMovements StockMovement[]
  stockTakeItems StockTakeItem[]

  @@unique([kantinSlug, name])
  @@index([kantinSlug, kind])
}

// =========================================================================
// GRN — Goods Receipt Note
// =========================================================================

enum GrnStatus {
  DRAFT
  POSTED
  CANCELED
}

model Grn {
  id          String    @id @default(cuid())
  kantinSlug  String
  grnNumber   String    // human-readable e.g. GRN-2026-0001
  vendorId    String?
  receivedAt  DateTime
  invoiceRef  String?   // vendor's invoice number
  notes       String?
  status      GrnStatus @default(DRAFT)
  totalValue  Float     @default(0)
  createdById String
  postedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  kantin    Kantin     @relation(fields: [kantinSlug], references: [slug])
  vendor    Vendor?    @relation(fields: [vendorId], references: [id])
  createdBy User       @relation("GrnCreatedBy", fields: [createdById], references: [id])
  lines     GrnLine[]

  @@unique([kantinSlug, grnNumber])
  @@index([kantinSlug, receivedAt])
}

model GrnLine {
  id        String  @id @default(cuid())
  grnId     String
  productId String
  qty       Float
  unitCost  Float
  lineTotal Float
  notes     String?

  grn     Grn     @relation(fields: [grnId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([grnId])
  @@index([productId])
}

// =========================================================================
// STOCK MOVEMENTS — append-only ledger of every stock change
// =========================================================================

enum StockMovementKind {
  GRN              // stock in from goods receipt
  SALE             // stock out from POS sale (auto-deducted via recipe)
  WASTAGE          // thrown away
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT       // manual correction (positive or negative qty)
  STOCK_TAKE       // adjustment from a stock take session
  OPENING_BALANCE
}

model StockMovement {
  id          String            @id @default(cuid())
  kantinSlug  String
  productId   String
  kind        StockMovementKind
  qty         Float             // positive = stock in, negative = stock out
  unitCost    Float?
  refType     String?           // e.g. "GRN", "SALE_TICKET", "STOCK_TAKE"
  refId       String?
  notes       String?
  occurredAt  DateTime
  createdById String?
  createdAt   DateTime          @default(now())

  kantin    Kantin   @relation(fields: [kantinSlug], references: [slug])
  product   Product  @relation(fields: [productId], references: [id])
  createdBy User?    @relation("StockMovementBy", fields: [createdById], references: [id])

  @@index([kantinSlug, productId, occurredAt])
  @@index([kind, occurredAt])
}

// =========================================================================
// STOCK TAKES — physical inventory count sessions
// =========================================================================

enum StockTakeStatus {
  IN_PROGRESS
  SUBMITTED   // counter has entered all qtys, awaiting approval
  APPROVED    // posted as adjustments
  CANCELED
}

model StockTake {
  id          String          @id @default(cuid())
  kantinSlug  String
  takeNumber  String          // human-readable e.g. STK-2026-0001
  startedAt   DateTime        @default(now())
  submittedAt DateTime?
  approvedAt  DateTime?
  notes       String?
  status      StockTakeStatus @default(IN_PROGRESS)
  createdById String

  kantin    Kantin          @relation(fields: [kantinSlug], references: [slug])
  createdBy User            @relation("StockTakeBy", fields: [createdById], references: [id])
  items     StockTakeItem[]

  @@unique([kantinSlug, takeNumber])
  @@index([kantinSlug, status])
}

model StockTakeItem {
  id          String  @id @default(cuid())
  stockTakeId String
  productId   String
  expectedQty Float   // computed from StockMovement ledger at start
  countedQty  Float?  // entered by counter
  variance    Float?  // counted - expected
  notes       String?

  stockTake StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([stockTakeId, productId])
  @@index([stockTakeId])
}

// =========================================================================
// POS SYNC — receives raw deltas from canteen PC mirror pushes
// =========================================================================

/// Stores each batch of rows pushed from a canteen PC.
/// Raw JSON for now so we never lose data; structured extraction happens later.
model SyncBatch {
  id           String   @id @default(cuid())
  kantinSlug   String
  receivedAt   DateTime @default(now())
  table        String   // source table name (e.g. "CHECKOUT", "ITEMSALE")
  rowCount     Int
  rows         Json     // array of row objects, each shaped like the source table
  highestId    Int?     // max id in this batch (used as next watermark)
  bytes        Int      @default(0)

  @@index([kantinSlug, table, receivedAt])
  @@index([kantinSlug, receivedAt])
  @@map("sync_batch")
}

/// Per-(kantin, table) high-water mark and stats. One row per table per kantin.
model SyncState {
  id          String    @id @default(cuid())
  kantinSlug  String
  tableName   String
  lastSeenId  Int?      // for incremental tables (CHECKOUT, ITEMSALE, etc.)
  lastSyncAt  DateTime?
  totalBatches Int      @default(0)
  totalRows   Int       @default(0)

  @@unique([kantinSlug, tableName])
  @@map("sync_state")
}

/// Bearer tokens the canteen PCs use to authenticate to /api/sync/[kantin].
/// One row per kantin. tokenHash is bcrypt of the raw token.
model SyncToken {
  id          String    @id @default(cuid())
  kantinSlug  String    @unique
  tokenHash   String
  description String?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  lastIp      String?
  isActive    Boolean   @default(true)

  @@map("sync_token")
}
