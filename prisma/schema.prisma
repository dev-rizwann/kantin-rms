// Kantin RMS — Postgres schema
// Runs on the Coolify-managed Postgres. See PLAN.md for the full design.
//
// PHASE 0 FOUNDATIONS applied:
//  - UoM system (UnitOfMeasure / UomConversion / ProductUom)
//  - Append-only StockMovement ledger hardened: idempotency unique key,
//    REVERSAL/PURCHASE_RETURN/PRODUCTION kinds, reversedById, valueDelta, Decimal
//  - ProductCostHistory (the one legitimately cached path-dependent number)
//  - AuditLog (append-only who/what/when)
//  - StorageLocation
//  - Money/qty fields migrated Float -> Decimal
//
// Non-negotiable rules (see PLAN.md §2):
//  1. StockMovement is APPEND-ONLY. Corrections = compensating REVERSAL rows.
//  2. Stock-on-hand = SUM(qty) from stock_movement. No cached stock columns.
//  3. Idempotency via @@unique([kantinSlug, refType, refId, productId]).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================================
// AUTH
// =========================================================================

enum Role {
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(VIEWER)
  kantinSlug   String?  // null = global (all kantins). admins are typically global.
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  grnsCreated      Grn[]            @relation("GrnCreatedBy")
  stockMovementsBy StockMovement[]  @relation("StockMovementBy")
  stockTakesBy     StockTake[]      @relation("StockTakeBy")
  auditLogs        AuditLog[]

  @@index([kantinSlug])
}

// =========================================================================
// KANTINS
// =========================================================================

model Kantin {
  slug        String   @id
  name        String
  city        String
  fullAddress String?
  isLive      Boolean  @default(false)
  // Phase-0 config additions
  defaultCurrency String @default("PKR")
  timezone        String @default("Asia/Karachi")
  ntn             String?
  strn            String?
  fbrPosRegNo     String?
  createdAt   DateTime @default(now())

  vendors          Vendor[]
  products         Product[]
  grns             Grn[]
  stockMovements   StockMovement[]
  stockTakes       StockTake[]
  storageLocations StorageLocation[]
}

// =========================================================================
// UNIT OF MEASURE SYSTEM
// =========================================================================

enum UomDimension {
  MASS
  VOLUME
  COUNT
}

enum ProductUomRole {
  PURCHASE
  COUNT
  STOCK
  BOTH
}

/// Canonical units. Global (not kantin-scoped). Conversions only within a dimension.
/// Seeded 1:1 from the StockUnit enum + Pakistani units (BORI/MAUND/TIN/...).
model UnitOfMeasure {
  code               String       @id // KG, GRAM, LITRE, ML, PIECE, PACK, BOX, BOTTLE, DOZEN, BORI, MAUND, TIN, CAN, CRATE, TRAY, PACKET
  name               String
  nameUr             String?
  dimension          UomDimension
  isBaseForDimension Boolean      @default(false) // GRAM for MASS, ML for VOLUME, PIECE for COUNT
  ratioToBase        Decimal      @db.Decimal(20, 6) // base units in one of this unit (KG->1000, LITRE->1000, PIECE->1)
  isActive           Boolean      @default(true)
  sortOrder          Int          @default(0)

  productsStock  Product[]   @relation("ProductStockUom")
  productUoms    ProductUom[]
  convFrom       UomConversion[] @relation("UomConvFrom")
  convTo         UomConversion[] @relation("UomConvTo")

  @@index([dimension])
}

/// Dimension-level conversion factors (kg<->g, l<->ml, dozen=12). NOT product-specific.
/// ratioToBase on UnitOfMeasure already encodes this; this table is the explicit,
/// test-asserted pair table for mass-conservation tests.
model UomConversion {
  id          String       @id @default(cuid())
  fromUomCode String
  toUomCode   String
  factor      Decimal      @db.Decimal(20, 6) // multiply a fromUom qty by factor -> toUom qty
  dimension   UomDimension
  note        String?

  fromUom UnitOfMeasure @relation("UomConvFrom", fields: [fromUomCode], references: [code])
  toUom   UnitOfMeasure @relation("UomConvTo", fields: [toUomCode], references: [code])

  @@unique([fromUomCode, toUomCode])
}

/// Per-product alternate units whose size is product-specific (1 BORI rice = 25 kg;
/// 1 BOX = 24 bottles). Reconciles purchase/count units to the product's stock UoM.
/// This is where cross-dimension bridges live (1 bun = 55 g).
model ProductUom {
  id            String         @id @default(cuid())
  productId     String
  uomCode       String
  qtyInStockUom Decimal        @db.Decimal(20, 6) // how many of the product's stock UoM are in one of THIS unit
  role          ProductUomRole @default(PURCHASE)
  isDefaultPurchase Boolean    @default(false)
  isActive      Boolean        @default(true)

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  uom     UnitOfMeasure @relation(fields: [uomCode], references: [code])

  @@unique([productId, uomCode])
  @@index([productId])
}

// =========================================================================
// VENDORS / SUPPLIERS
// =========================================================================

enum SupplyCadence {
  DAILY_FRESH
  WEEKLY
  MONTHLY
  AGGREGATOR
  CASH_MARKET
}

model Vendor {
  id              String   @id @default(cuid())
  kantinSlug      String
  name            String
  nameUr          String?
  contactPerson   String?
  contact         String?
  phone           String?
  whatsapp        String?
  address         String?
  notes           String?
  isActive        Boolean  @default(true)
  // terms + cadence
  paymentTermsDays Int?
  leadTimeDays     Int?
  deliveryDays     String?  // CSV of weekday names, optional
  supplyCadence    SupplyCadence?
  // tax identity (Pakistan)
  ntn              String?
  strn             String?
  isSalesTaxRegistered Boolean @default(false)
  // payout rails
  bankName         String?
  bankAccountTitle String?
  bankAccountNumber String?
  iban             String?
  jazzcashNumber   String?
  easypaisaNumber  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kantin Kantin @relation(fields: [kantinSlug], references: [slug])
  grns   Grn[]

  @@index([kantinSlug])
}

// =========================================================================
// PRODUCTS / RAW MATERIALS
// =========================================================================

enum ProductKind {
  RAW_MATERIAL // ingredients (potato, oil, cheese)
  PACKAGING    // boxes, paper bags
  RESALE       // bottles of water, packaged drinks
  SUPPLIES     // non-food consumables
}

/// Legacy enum kept one release for migration; superseded by UnitOfMeasure.
enum StockUnit {
  KG
  GRAM
  LITRE
  ML
  PIECE
  PACK
  BOX
  BOTTLE
}

enum CountFrequency {
  DAILY
  WEEKLY
  MONTHLY
  TERM
}

model Product {
  id           String      @id @default(cuid())
  kantinSlug   String
  sku          String?
  name         String
  nameUr       String?
  kind         ProductKind @default(RAW_MATERIAL)
  unit         StockUnit   @default(PIECE) // legacy; being replaced by stockUomCode
  stockUomCode String?     // canonical stock unit (backfilled from `unit`)
  minStock     Decimal     @default(0) @db.Decimal(20, 6)
  reorderQty   Decimal?    @db.Decimal(20, 6)
  // costing
  avgCost          Decimal? @db.Decimal(14, 6) // weighted-average, recomputed on GRN
  lastPurchaseCost Decimal? @db.Decimal(14, 6)
  // misc
  preferredVendorId   String?
  inventoryCategoryId String?
  masterProductId     String?  // null = local-only product
  countFrequency      CountFrequency @default(WEEKLY)
  lastCountedAt       DateTime?
  isActive            Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  kantin         Kantin              @relation(fields: [kantinSlug], references: [slug])
  stockUom       UnitOfMeasure?      @relation("ProductStockUom", fields: [stockUomCode], references: [code])
  productUoms    ProductUom[]
  grnLines       GrnLine[]
  stockMovements StockMovement[]
  stockTakeItems StockTakeItem[]
  costHistory    ProductCostHistory[]

  @@unique([kantinSlug, name])
  @@index([kantinSlug, kind])
}

/// Audit trail of weighted-average cost recomputes. The ONE legitimately
/// path-dependent cached number (it is COST, not on-hand qty). Makes valuation reproducible.
model ProductCostHistory {
  id              String   @id @default(cuid())
  productId       String
  effectiveAt     DateTime
  oldAvgCost      Decimal? @db.Decimal(14, 6)
  newAvgCost      Decimal  @db.Decimal(14, 6)
  qtyOnHandAtCalc Decimal  @db.Decimal(20, 6)
  inboundQty      Decimal  @db.Decimal(20, 6)
  inboundUnitCost Decimal  @db.Decimal(14, 6)
  sourceType      String   // GRN | OPENING_BALANCE | ADJUSTMENT
  sourceId        String?
  createdAt       DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, effectiveAt])
}

// =========================================================================
// STORAGE LOCATIONS (optional sub-locations; null collapses to one bucket)
// =========================================================================

enum StorageLocationKind {
  STORE
  KITCHEN
  FRIDGE
  FREEZER
  OTHER
}

model StorageLocation {
  id         String              @id @default(cuid())
  kantinSlug String
  name       String
  kind       StorageLocationKind @default(STORE)
  isDefault  Boolean             @default(false)
  createdAt  DateTime            @default(now())

  kantin         Kantin          @relation(fields: [kantinSlug], references: [slug])
  stockMovements StockMovement[]

  @@unique([kantinSlug, name])
  @@index([kantinSlug])
}

// =========================================================================
// GRN — Goods Receipt Note
// =========================================================================

enum GrnStatus {
  DRAFT
  POSTED
  CANCELED
}

model Grn {
  id          String    @id @default(cuid())
  kantinSlug  String
  grnNumber   String
  vendorId    String?
  receivedAt  DateTime
  invoiceRef  String?
  isInformal  Boolean   @default(false) // cash-market buy, no formal invoice
  notes       String?
  status      GrnStatus @default(DRAFT)
  storageLocationId String?
  receivedById      String?
  challanPhotoUrl   String?
  subtotal    Decimal   @default(0) @db.Decimal(14, 2)
  taxTotal    Decimal   @default(0) @db.Decimal(14, 2)
  grandTotal  Decimal   @default(0) @db.Decimal(14, 2)
  createdById String
  postedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  kantin    Kantin     @relation(fields: [kantinSlug], references: [slug])
  vendor    Vendor?    @relation(fields: [vendorId], references: [id])
  createdBy User       @relation("GrnCreatedBy", fields: [createdById], references: [id])
  lines     GrnLine[]

  @@unique([kantinSlug, grnNumber])
  @@index([kantinSlug, receivedAt])
}

model GrnLine {
  id            String  @id @default(cuid())
  grnId         String
  productId     String
  uomCode       String? // unit the receivedQty was entered in
  qty           Decimal @db.Decimal(20, 6) // received qty (in uomCode)
  qtyInStockUom Decimal @default(0) @db.Decimal(20, 6) // converted snapshot posted to ledger
  rejectedQty   Decimal @default(0) @db.Decimal(20, 6) // refused at door, never enters stock
  unitCost      Decimal @db.Decimal(14, 6) // per uomCode
  lineTotal     Decimal @db.Decimal(14, 2)
  taxRatePct    Decimal @default(0) @db.Decimal(6, 4)
  taxAmount     Decimal @default(0) @db.Decimal(14, 2)
  batchNo       String?
  expiryDate    DateTime?
  notes         String?

  grn     Grn     @relation(fields: [grnId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([grnId])
  @@index([productId])
}

// =========================================================================
// STOCK MOVEMENTS — the append-only ledger (single source of truth)
// =========================================================================

enum StockMovementKind {
  GRN
  SALE
  WASTAGE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  STOCK_TAKE
  OPENING_BALANCE
  REVERSAL          // compensating entry that negates an earlier movement
  PURCHASE_RETURN   // stock returned to vendor
  PRODUCTION        // prep/sub-recipe output (+) and its ingredient consumption (-)
}

model StockMovement {
  id          String            @id @default(cuid())
  kantinSlug  String
  productId   String
  kind        StockMovementKind
  qty         Decimal           @db.Decimal(20, 6) // + = stock in, - = stock out; ALWAYS in product stock UoM
  unitCost    Decimal?          @db.Decimal(14, 6)
  valueDelta  Decimal?          @db.Decimal(14, 2) // qty * unitCost, signed
  uomCode     String?           // informational; qty is already in stock UoM
  refType     String?           // GRN | SALE_ITEMLINE | SALE_REVERSAL | STOCK_TAKE | WASTAGE | TRANSFER | ...
  refId       String?
  reversedById String?          // points at the movement this one reverses
  recipeId    String?           // SALE traceability
  recipeVersion Int?
  storageLocationId String?
  notes       String?
  occurredAt  DateTime          // business time
  createdById String?
  createdAt   DateTime          @default(now()) // insert time

  kantin          Kantin           @relation(fields: [kantinSlug], references: [slug])
  product         Product          @relation(fields: [productId], references: [id])
  createdBy       User?            @relation("StockMovementBy", fields: [createdById], references: [id])
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id])
  reversedBy      StockMovement?   @relation("Reversal", fields: [reversedById], references: [id])
  reversals       StockMovement[]  @relation("Reversal")

  // IDEMPOTENCY: one movement per (kantin, refType, refId, product).
  // SALE and its SALE_REVERSAL use DIFFERENT refType so both coexist.
  @@unique([kantinSlug, refType, refId, productId])
  @@index([kantinSlug, productId, occurredAt])
  @@index([kind, occurredAt])
}

// =========================================================================
// STOCK TAKES
// =========================================================================

enum StockTakeStatus {
  IN_PROGRESS
  SUBMITTED
  APPROVED
  CANCELED
}

enum StockTakeKind {
  FULL
  CYCLE
  PARTIAL
}

model StockTake {
  id          String          @id @default(cuid())
  kantinSlug  String
  takeNumber  String
  type        StockTakeKind   @default(FULL)
  frozenAt    DateTime?       // snapshot watermark for expectedQty
  blindCount  Boolean         @default(false)
  storageLocationId String?
  startedAt   DateTime        @default(now())
  submittedAt DateTime?
  approvedAt  DateTime?
  submittedById String?
  approvedById  String?
  rejectedReason String?
  notes       String?
  status      StockTakeStatus @default(IN_PROGRESS)
  createdById String

  kantin    Kantin          @relation(fields: [kantinSlug], references: [slug])
  createdBy User            @relation("StockTakeBy", fields: [createdById], references: [id])
  items     StockTakeItem[]

  @@unique([kantinSlug, takeNumber])
  @@index([kantinSlug, status])
}

model StockTakeItem {
  id               String  @id @default(cuid())
  stockTakeId      String
  productId        String
  countedUomCode   String?
  expectedQty      Decimal @db.Decimal(20, 6) // frozen at frozenAt
  countedQty       Decimal? @db.Decimal(20, 6) // BLANK by default — forces a real count
  variance         Decimal? @db.Decimal(20, 6)
  unitCostSnapshot Decimal? @db.Decimal(14, 6)
  varianceValue    Decimal? @db.Decimal(14, 2)
  reasonCode       String?
  reasonNote       String?
  isFlagged        Boolean @default(false)
  countedById      String?
  notes            String?

  stockTake StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([stockTakeId, productId])
  @@index([stockTakeId])
}

// =========================================================================
// AUDIT LOG — append-only who/what/when (distinct from the quantity ledger)
// =========================================================================

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorRole  String?
  kantinSlug String?
  action     String   // grn.posted, stocktake.approved, recipe.updated, user.created, ...
  entityType String?
  entityId   String?
  summary    String?
  metadata   Json?
  ip         String?
  occurredAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([kantinSlug, occurredAt])
  @@index([action, occurredAt])
}

// =========================================================================
// POS SYNC — receives raw deltas from canteen PC mirror pushes
// =========================================================================

model SyncBatch {
  id         String   @id @default(cuid())
  kantinSlug String
  receivedAt DateTime @default(now())
  table      String
  rowCount   Int
  rows       Json
  highestId  Int?
  bytes      Int      @default(0)

  @@index([kantinSlug, table, receivedAt])
  @@index([kantinSlug, receivedAt])
  @@map("sync_batch")
}

model SyncState {
  id           String    @id @default(cuid())
  kantinSlug   String
  tableName    String
  lastSeenId   Int?
  lastSyncAt   DateTime?
  totalBatches Int       @default(0)
  totalRows    Int       @default(0)

  @@unique([kantinSlug, tableName])
  @@map("sync_state")
}

model SyncToken {
  id          String    @id @default(cuid())
  kantinSlug  String    @unique
  tokenHash   String
  description String?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  lastIp      String?
  isActive    Boolean   @default(true)

  @@map("sync_token")
}
